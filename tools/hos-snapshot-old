#!/bin/sh
# HOS Snapshot - Automatic System Configuration Tracker

set -e

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CONFIGS_DIR="$PROJECT_DIR/configs"
TRACKED_PATHS="/etc/hos/tracked-paths.conf"

echo "HOS Snapshot"
echo "==============="

# Checking if tracking is installed
if [ ! -f "$TRACKED_PATHS" ]; then
    echo "HOS tools not installed. Run first:"
    echo "   sudo ./scripts/installer.sh"
    exit 1
fi

# Create a folder structure
mkdir -p "$CONFIGS_DIR/etc/init.d" "$CONFIGS_DIR/root" "$CONFIGS_DIR/usr/local/bin"

echo "Scanning tracked paths..."

# Reading and processing traced paths
while IFS= read -r pattern; do
    # Skipping blank lines and comments
    [ -z "$pattern" ] || [ "${pattern#\#}" != "$pattern" ] && continue
    
    echo "Processing: $pattern"
    
    # Processing templates with *
    if echo "$pattern" | grep -q '\*'; then
        for file in $pattern; do
            if [ -f "$file" ]; then
                rel_path="${file#/}"
                dir_path="$CONFIGS_DIR/$(dirname "$rel_path")"
                mkdir -p "$dir_path"
                echo "  Saving: $file"
                cp "$file" "$CONFIGS_DIR/$rel_path" 2>/dev/null || sudo cp "$file" "$CONFIGS_DIR/$rel_path"
            fi
        done
    else
        # Regular files
        if [ -f "$pattern" ] || [ -d "$pattern" ]; then
            rel_path="${pattern#/}"
            dir_path="$CONFIGS_DIR/$(dirname "$rel_path")"
            mkdir -p "$dir_path"
            echo "  Saving: $pattern"
            cp "$pattern" "$CONFIGS_DIR/$rel_path" 2>/dev/null || sudo cp "$pattern" "$CONFIGS_DIR/$rel_path"
        fi
    fi
done < "$TRACKED_PATHS"

# Saving the list of packages
echo "Saving package list..."
apk info -v > "$CONFIGS_DIR/packages.txt" 2>/dev/null || true

# Saving the list of services
echo "Saving services..."
rc-update show > "$CONFIGS_DIR/services.txt" 2>/dev/null || true

# Create a change log
echo "Creating changelog entry..."
if [ ! -f "$CONFIGS_DIR/changelog.txt" ]; then
    echo "HOS Configuration Changelog" > "$CONFIGS_DIR/changelog.txt"
    echo "===========================" >> "$CONFIGS_DIR/changelog.txt"
fi

echo "" >> "$CONFIGS_DIR/changelog.txt"
echo "$(date '+%Y-%m-%d %H:%M:%S') - $(hostname)" >> "$CONFIGS_DIR/changelog.txt"
echo "----------------------------------------" >> "$CONFIGS_DIR/changelog.txt"

if [ -t 0 ]; then
    echo "Describe your changes (Ctrl+D to finish):"
    while IFS= read -r line; do
        echo "  $line" >> "$CONFIGS_DIR/changelog.txt"
    done
else
    echo "  [No description]" >> "$CONFIGS_DIR/changelog.txt"
fi

echo ""
echo "Snapshot complete!"
echo ""
echo "Saved to: $CONFIGS_DIR/"
echo "Files saved: $(find "$CONFIGS_DIR" -type f | wc -l)"
echo ""
echo "Next steps:"
echo "   git status                 # See what changed"
echo "   git add .                  # Add all files"
echo "   git commit -m 'description' # Commit changes"
echo "   git push                   # Push to GitHub"

chmod +x tools/hos-snapshot